# Business Wise read-only import (Task 7) — local environment configuration.
#
# This file documents variable NAMES only. Never fill in real values here
# and never commit a file containing real values — copy this to a local
# `.env` (already gitignored) and fill in your own local credentials there.
#
# Only used by the manual live-database smoke test (`bun run bwi:smoke --
# --live`) and the direct SQL Server adapter (src/sources/bwi/live-adapter.ts).
# The ordinary local pipeline (`bun run reset`, `bun test`, `bun run
# bwi:import`) never reads these and never connects to a live database.
#
# See docs/BWI_READ_ONLY_IMPORT.md for full setup instructions.

# Hostname/IP of the BWI SQL Server instance. Never commit a real value.
BWI_DB_SERVER=

# Database name.
BWI_DB_NAME=

# SQL authentication credentials for a READ-ONLY login. Never commit real values.
BWI_DB_USER=
BWI_DB_PASSWORD=

# Optional. Defaults to SQL Server's standard port (1433) if unset.
BWI_DB_PORT=1433

# Optional. Defaults to true (encrypted connection).
BWI_DB_ENCRYPT=true

# Optional. Defaults to false. Only set to true for a trusted local/dev
# server with a self-signed certificate — never for a real production
# connection.
BWI_DB_TRUST_SERVER_CERTIFICATE=false

# Optional. Defaults to true. Requests read-only routing when the target
# supports Always On readable secondaries. Set to false if the target
# server rejects this connection option.
BWI_DB_READ_ONLY_INTENT=true
