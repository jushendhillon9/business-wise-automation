node_modules/
data/sandbox.sqlite
data/sandbox.sqlite-*

# Disposable per-test-file sqlite databases (db.test.ts, ingestion.test.ts,
# review-decisions.test.ts, and any future ones) plus their WAL/SHM sidecars
# -- see src/test-support/sqlite-test-db.ts.
data/*.test.sqlite
data/*.test.sqlite-shm
data/*.test.sqlite-wal

# Private, production-derived Business Wise snapshot data (real DFW BWI
# records/relationships). Never committed -- see data/private/bwi/README.md.
data/private/bwi/*.csv
data/private/bwi/*.tsv
data/private/bwi/*.json
data/private/bwi/*.db
data/private/bwi/*.sqlite

# Private local pulls from external source profilers (e.g. the Texas
# sales-tax-permit profiler) -- raw observations, profiles, and pilot
# samples never committed. See src/tx-permits-profile.ts.
data/private/sources/

.env
.env.*
!.env.example
